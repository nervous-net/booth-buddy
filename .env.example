# Database
DATABASE_URL="postgresql://user:password@localhost:5432/booth_buddy?schema=public"

# Shopify App Credentials (from Partner Dashboard)
SHOPIFY_API_KEY="your_shopify_api_key"
SHOPIFY_API_SECRET="your_shopify_api_secret"
SHOPIFY_SCOPES="read_customers,write_customers"

# Security Keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="your_64_char_hex_key_for_encrypting_tokens"
SESSION_SECRET="your_64_char_hex_key_for_csrf_protection"

# URLs
APP_URL="http://localhost:3000"

# Environment
NODE_ENV="development"
