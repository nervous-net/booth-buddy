<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f6f6f7;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .card {
      background: white;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      padding: 40px;
      width: 100%;
      max-width: 400px;
      text-align: center;
    }
    .icon {
      font-size: 64px;
      margin-bottom: 16px;
    }
    h1 {
      font-size: 24px;
      margin-bottom: 8px;
      color: #202223;
    }
    .event-name {
      font-weight: 600;
      color: #667eea;
    }
    .message {
      color: #6d7175;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">Ended</div>
    <h1>Event Has Ended</h1>
    <p class="message">
      <span class="event-name"><%= eventName %></span> is no longer accepting signups.
    </p>
  </div>
</body>
</html>
