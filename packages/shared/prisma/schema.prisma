generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify store installations
model Shop {
  id          String   @id @default(uuid())
  shopDomain  String   @unique @map("shop_domain")
  accessToken String   @map("access_token") // Encrypted
  scopes      String
  installedAt DateTime @default(now()) @map("installed_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  events Event[]
  scans  EventScan[]

  @@map("shops")
}

// Events (each has a unique QR code)
model Event {
  id     String @id @default(uuid())
  shopId String @map("shop_id")
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name     String // "ComicCon 2026"
  slug     String // "comiccon-2026" (URL-safe, unique per shop)
  tag      String // "booth_comiccon2026" (Shopify customer tag)
  isActive Boolean   @default(true) @map("is_active")
  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  scans EventScan[]

  @@unique([shopId, slug])
  @@index([slug])
  @@map("events")
}

// Record of each customer scan/registration
model EventScan {
  id      String @id @default(uuid())
  shopId  String @map("shop_id")
  shop    Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  email             String // Customer email (for reference)
  shopifyCustomerId String  @map("shopify_customer_id")
  wasNewCustomer    Boolean @default(false) @map("was_new_customer")

  scannedAt DateTime @default(now()) @map("scanned_at")
  ipAddress String?  @map("ip_address") // For rate limiting analytics

  @@unique([eventId, email])
  @@index([shopId, scannedAt])
  @@map("event_scans")
}
