{
  "name": "booth-buddy",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Booth Buddy - QR code customer tagging for in-person events",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev -w @booth-buddy/web",
    "start": "node packages/web/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src/**/*.ts --no-warn-ignored",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix --no-warn-ignored",
    "typecheck": "npm run typecheck --workspaces",
    "db:generate": "npm run db:generate -w @booth-buddy/shared",
    "db:push": "npm run db:push -w @booth-buddy/shared",
    "db:migrate": "npm run db:migrate -w @booth-buddy/shared"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^9.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
